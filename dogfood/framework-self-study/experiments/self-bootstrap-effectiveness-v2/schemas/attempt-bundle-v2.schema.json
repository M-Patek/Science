{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Immutable self-bootstrap attempt bundle v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "attempt_id", "opaque_cell_token", "attempt_ordinal", "subject_packet_sha256", "baseline", "identities", "local_evidence", "timing", "evidence", "stop_reason", "censor", "deviations", "critical_violations", "finalized_sha256"],
  "properties": {
    "schema_version": {"const": 2},
    "attempt_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,127}$"},
    "opaque_cell_token": {"type": "string", "minLength": 16},
    "attempt_ordinal": {"const": 1},
    "subject_packet_sha256": {"$ref": "#/$defs/sha256"},
    "baseline": {"type": "object", "additionalProperties": false, "required": ["git_commit", "git_tree"], "properties": {"git_commit": {"$ref": "#/$defs/git"}, "git_tree": {"$ref": "#/$defs/git"}}},
    "identities": {
      "type": "object", "additionalProperties": false,
      "required": ["planned_session_id", "planned_worktree_id", "planned_context_id", "native_agent_id", "observed_harness_session_id", "observed_cwd", "observed_head_commit"],
      "properties": {
        "planned_session_id": {"type": "string", "minLength": 1},
        "planned_worktree_id": {"type": "string", "minLength": 1},
        "planned_context_id": {"type": "string", "minLength": 1},
        "native_agent_id": {"type": "string", "minLength": 1},
        "observed_harness_session_id": {"type": "string", "minLength": 1},
        "observed_cwd": {"type": "string", "minLength": 1},
        "observed_head_commit": {"$ref": "#/$defs/git"}
      }
    },
    "local_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_level", "harness_receipt_sha256", "local_dispatch_acceptance_sha256", "execution_gate_sha256", "non_claims"],
      "properties": {
        "evidence_level": {"const": "host-observed-unsigned"},
        "harness_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "local_dispatch_acceptance_sha256": {"$ref": "#/$defs/sha256"},
        "execution_gate_sha256": {"$ref": "#/$defs/sha256"},
        "non_claims": {"const": ["provider_identity", "immutable_model_build", "prompt_identity", "toolchain_completeness", "network_enforcement", "permission_enforcement", "context_isolation", "absolute_worktree_isolation"]}
      }
    },
    "timing": {"type": "object", "additionalProperties": false, "required": ["task_received_utc", "ended_utc", "elapsed_seconds"], "properties": {"task_received_utc": {"type": "string", "format": "date-time"}, "ended_utc": {"type": "string", "format": "date-time"}, "elapsed_seconds": {"type": "number", "minimum": 0}}},
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["transcript_or_events_sha256", "command_log_sha256", "patch_sha256", "outputs_sha256", "tests_sha256", "handoff_sha256"],
      "properties": {
        "transcript_or_events_sha256": {"$ref": "#/$defs/sha256"},
        "command_log_sha256": {"$ref": "#/$defs/sha256"},
        "patch_sha256": {"$ref": "#/$defs/sha256"},
        "outputs_sha256": {"$ref": "#/$defs/sha256"},
        "tests_sha256": {"$ref": "#/$defs/sha256"},
        "handoff_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "stop_reason": {"enum": ["completed", "timeout", "context-exhaustion", "explicit-block", "critical-violation", "infrastructure-failure", "refusal", "test-failure"]},
    "censor": {"type": "object", "additionalProperties": false, "required": ["status", "reason"], "properties": {"status": {"enum": ["not-censored", "setup-censored"]}, "reason": {"type": ["string", "null"]}}},
    "deviations": {"type": "array", "items": {"type": "string"}},
    "critical_violations": {"type": "array", "items": {"type": "string"}},
    "finalized_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
  }
}
