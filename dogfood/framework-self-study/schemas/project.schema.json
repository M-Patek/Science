{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/science-workbench/project.schema.json",
  "title": "Science Workbench research project",
  "type": "object",
  "required": ["schema_version", "id", "name", "kind", "owner", "framework", "contracts"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "name": {"type": "string", "minLength": 1},
    "kind": {"const": "research-project"},
    "owner": {"type": "string", "minLength": 1},
    "framework": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "science-workbench"},
        "version": {"type": "string"}
      }
    },
    "contracts": {
      "type": "object",
      "required": ["experiment", "campaign", "handoff"]
    }
  }
}
