{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-workbench.local/schemas/attempt-manifest.schema.json",
  "title": "Attempt manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cohort_id",
    "attempts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "cohort_id": {
      "type": "string",
      "minLength": 1
    },
    "attempts": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "cell_id",
          "attempt_ordinal"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\\\\\).+$"
          },
          "cell_id": {
            "type": "string",
            "minLength": 1
          },
          "attempt_ordinal": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
