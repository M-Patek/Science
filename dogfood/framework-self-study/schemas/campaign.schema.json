{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/science-workbench/campaign.schema.json",
  "title": "Science Workbench multi-agent campaign",
  "type": "object",
  "required": ["schema_version", "id", "title", "objective", "status", "owner", "tasks"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "title": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "approved", "running", "review", "complete", "blocked", "abandoned"]},
    "owner": {"type": "string"},
    "framework_revision_under_test": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "human_gates": {"type": "array", "items": {"type": "object"}},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "status", "depends_on", "inputs", "outputs", "write_scope", "review_required", "human_gate"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "status": {"enum": ["pending", "ready", "claimed", "running", "review", "complete", "blocked", "failed"]},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "inputs": {"type": "array", "items": {"type": "string"}},
          "outputs": {"type": "array", "items": {"type": "string"}},
          "write_scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "review_required": {"type": "boolean"},
          "human_gate": {"type": "boolean"}
        }
      }
    }
  }
}
