{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/science-workbench/run.schema.json",
  "title": "Science Workbench run record",
  "type": "object",
  "required": ["schema_version", "run_id", "experiment_id", "status", "started_at", "ended_at", "command", "exit_code", "manifest_sha256", "environment_sha256", "artifacts"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string"},
    "experiment_id": {"type": "string"},
    "status": {"enum": ["succeeded", "failed"]},
    "started_at": {"type": "string", "format": "date-time"},
    "ended_at": {"type": "string", "format": "date-time"},
    "duration_seconds": {"type": "number", "minimum": 0},
    "command": {"type": "array", "items": {"type": "string"}},
    "exit_code": {"type": "integer"},
    "git_revision": {"type": ["string", "null"]},
    "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "environment_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "inputs": {"type": "array", "items": {"type": "object", "required": ["path", "exists", "sha256", "bytes"]}},
    "artifacts": {"type": "array", "items": {"type": "object", "required": ["path", "exists", "sha256", "bytes"]}},
    "lineage": {
      "type": "object",
      "required": ["path", "sha256", "validation"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "validation": {
          "type": "object",
          "required": ["status", "schema"],
          "properties": {
            "status": {"enum": ["valid", "invalid", "not_validated_no_pinned_schema"]},
            "schema": {"type": ["string", "null"]},
            "errors": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    }
  }
}
