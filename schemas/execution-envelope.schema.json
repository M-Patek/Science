{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/science-workbench/execution-envelope.schema.json",
  "title": "Science Workbench runtime-neutral execution request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "project_id", "revision", "command", "working_directory", "inputs", "environment", "env_refs", "secret_refs", "resources", "sensitive_resources", "authorization", "idempotency_key"],
  "properties": {
    "schema_version": {"const": 1},
    "request_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "project_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "revision": {"type": "string", "minLength": 1},
    "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "working_directory": {"type": "string", "minLength": 1},
    "inputs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest"], "properties": {"path": {"type": "string"}, "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}}},
    "environment": {"type": "object", "additionalProperties": false, "properties": {"MODE": {"enum": ["test", "development", "production"]}, "LOCALE": {"enum": ["C", "C.UTF-8", "en_US.UTF-8"]}, "PYTHONUNBUFFERED": {"enum": ["0", "1"]}}},
    "env_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "secret_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "resources": {"type": "object", "additionalProperties": true, "required": ["cost_ceiling"], "properties": {"cost_ceiling": {"type": "object", "additionalProperties": false, "required": ["amount", "currency"], "properties": {"amount": {"type": "number", "minimum": 0}, "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}}}}},
    "sensitive_resources": {"type": "object", "additionalProperties": false, "required": ["external_compute", "private_data", "instrument", "cost_bearing"], "properties": {"external_compute": {"type": "boolean"}, "private_data": {"type": "boolean"}, "instrument": {"type": "boolean"}, "cost_bearing": {"type": "boolean"}}},
    "authorization": {"description": "Unattested lookup reference only; never proof of approval", "type": "object", "additionalProperties": false, "required": ["reference"], "properties": {"reference": {"type": "string", "minLength": 1}}},
    "idempotency_key": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
